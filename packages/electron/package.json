{
  "name": "nansuka-electron",
  "version": "1.0.0",
  "private": true,
  "description": "Tray-resident translation app",
  "author": "hashrock",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "dev.hashrock.nansuka",
    "productName": "Nansuka",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "icon.png",
      "target": "dmg"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "iconTemplate.png",
      "iconTemplate@2x.png",
      "dist/**/*"
    ],
    "asarUnpack": [
      "node_modules/uiohook-napi/**"
    ],
    "npmRebuild": false
  }
}
